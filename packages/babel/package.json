{
  "name": "@ssets/babel",
  "version": "1.1.0",
  "description": "Babel for SSE SSE UI Builder",
  "type": "module",
  "exports": {
    "./plugin/*": {
      "import": "./dist/plugin/*.js",
      "types": "./dist/plugin/*.d.ts"
    },
    "./preset/*": {
      "import": "./dist/preset/*.js",
      "types": "./dist/preset/*.d.ts"
    },
    "./helper/*": {
      "import": "./dist/helper/*.js",
      "types": "./dist/helper/*.d.ts"
    },
    "./helper/validator-identifier": {
      "import": "./dist/helper/validator-identifier/index.js",
      "types": "./dist/helper/validator-identifier/index.d.ts"
    },
    "./vendors/*": {
      "import": "./dist/vendors/*.js",
      "types": "./dist/vendors/*.d.ts"
    },
    "./code-frame": {
      "import": "./dist/code-frame/index.js",
      "types": "./dist/code-frame/index.d.ts"
    },
    "./code-frame/*": {
      "import": "./dist/code-frame/*.js",
      "types": "./dist/code-frame/*.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json"
  },
  "author": "SSE Official",
  "license": "MIT",
  "dependencies": {
    "@babel/core": "^7.29.0",
    "@babel/helper-plugin-utils": "^7.28.6",
    "@babel/plugin-transform-react-jsx": "^7.28.6",
    "@babel/plugin-transform-runtime": "^7.29.0",
    "@babel/preset-env": "^7.29.0",
    "@babel/types": "^7.29.0",
    "@types/babel__plugin-transform-runtime": "^7.9.5",
    "@types/babel__preset-env": "^7.10.0",
    "babel-plugin-transform-remove-imports": "^1.8.1",
    "resolve": "^1.22.11"
  },
  "devDependencies": {
    "@types/babel__helper-plugin-utils": "^7.10.3"
  }
}

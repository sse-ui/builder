{
  "name": "build",
  "private": true,
  "license": "MIT",
  "author": "SSE Universe",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types"
  },
  "devDependencies": {
    "@mui/internal-babel-plugin-minify-errors": "^2.0.6",
    "prettier": "^3.7.4",
    "tsup": "^8.5.1",
    "turbo": "^2.8.15",
    "typescript": "5.9.2"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "npm@10.9.3",
  "workspaces": [
    "apps/*",
    "packages/*",
    "test-lib"
  ],
  "dependencies": {
    "@babel/plugin-transform-react-constant-elements": "^7.27.1"
  },
  "version": "1.0.0",
  "description": "`sse-tools` is a high-performance CLI utility designed for managing, building, and publishing software packages within the SSE ecosystem. It provides a unified interface for library development, supporting both Babel for individual file transpilation and esbuild for high-speed bundling.",
  "main": "index.js",
  "directories": {
    "doc": "docs",
    "example": "example"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sse-ui/builder.git"
  },
  "bugs": {
    "url": "https://github.com/sse-ui/builder/issues"
  },
  "homepage": "https://github.com/sse-ui/builder#readme"
}
